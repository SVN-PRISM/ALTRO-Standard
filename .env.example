ALTRO_OPERATOR_BYPASS_KEY=your_secret_key_here

# Ollama model tag for STENCIL /transcreate (browser — must be NEXT_PUBLIC_*)
NEXT_PUBLIC_DEFAULT_MODEL=your-ollama-tag-here # e.g., qwen3.5:9b

# /api/transcreate → Ollama: таймаут до первого байта ответа (мс). 14b cold load часто >60s; по умолчанию в коде 180000. 0 = отключить.
# OLLAMA_EMERGENCY_MS=180000
# OLLAMA_TIMEOUT_MS=600000

# Firebird connection (DATA SYNC / Sovereign Data Gateway)
FIREBIRD_HOST=127.0.0.1
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=/path/to/your/database.fdb
FIREBIRD_USER=sysdba
FIREBIRD_PASSWORD=masterkey
